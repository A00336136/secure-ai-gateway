		{
			"name": "Security Headers",
			"item": [
				{
					"name": "Check CORS",
					"request": {
						"method": "OPTIONS",
						"header": [
							{
								"key": "Origin",
								"value": "http://localhost:3000"
							},
							{
								"key": "Access-Control-Request-Method",
								"value": "POST"
							},
							{
								"key": "Access-Control-Request-Headers",
								"value": "Content-Type, Authorization"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/ask",
							"host": ["{{base_url}}"],
							"path": ["api", "ask"]
						},
						"description": "Test CORS preflight request handling"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('CORS preflight returns success', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
									"});",
									"",
									"pm.test('CORS headers present', function () {",
									"    pm.expect(",
									"        pm.response.headers.has('Access-Control-Allow-Origin') ||",
									"        pm.response.headers.has('access-control-allow-origin')",
									"    ).to.be.true;",
									"});",
									"",
									"pm.test('CORS allows required methods', function () {",
									"    var allowMethods = pm.response.headers.get('Access-Control-Allow-Methods') ||",
									"                      pm.response.headers.get('access-control-allow-methods') || '';",
									"    pm.expect(allowMethods.toLowerCase()).to.include('post');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Check CSP Header",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/health",
							"host": ["{{base_url}}"],
							"path": ["auth", "health"]
						},
						"description": "Inspect Content-Security-Policy header"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Response returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Content-Security-Policy header present', function () {",
									"    pm.expect(",
									"        pm.response.headers.has('Content-Security-Policy') ||",
									"        pm.response.headers.has('content-security-policy')",
									"    ).to.be.true;",
									"});",
									"",
									"// Log CSP value for review",
									"var csp = pm.response.headers.get('Content-Security-Policy') ||",
									"          pm.response.headers.get('content-security-policy');",
									"if (csp) {",
									"    console.log('CSP: ' + csp);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Check HSTS",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/health",
							"host": ["{{base_url}}"],
							"path": ["auth", "health"]
						},
						"description": "Inspect Strict-Transport-Security header"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Response returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Strict-Transport-Security header present', function () {",
									"    pm.expect(",
									"        pm.response.headers.has('Strict-Transport-Security') ||",
									"        pm.response.headers.has('strict-transport-security')",
									"    ).to.be.true;",
									"});",
									"",
									"// Log HSTS value for review",
									"var hsts = pm.response.headers.get('Strict-Transport-Security') ||",
									"           pm.response.headers.get('strict-transport-security');",
									"if (hsts) {",
									"    console.log('HSTS: ' + hsts);",
									"    pm.test('HSTS includes max-age', function () {",
									"        pm.expect(hsts).to.include('max-age');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "SQL Injection Test",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin' OR '1'='1' --\",\n  \"password\": \"anything\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Test SQL injection resistance on login endpoint"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SQL injection attempt fails', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403]);",
									"});",
									"",
									"pm.test('No database error exposed', function () {",
									"    var body = pm.response.text().toLowerCase();",
									"    pm.expect(body).to.not.include('sql');",
									"    pm.expect(body).to.not.include('syntax');",
									"    pm.expect(body).to.not.include('postgresql');",
									"    pm.expect(body).to.not.include('stacktrace');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "XSS Test",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"prompt\": \"<script>alert('xss')</script>What is AI?\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/ask",
							"host": ["{{base_url}}"],
							"path": ["api", "ask"]
						},
						"description": "Test XSS payload handling in API requests"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Response received', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
									"});",
									"",
									"pm.test('XSS payload not reflected raw', function () {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.not.include(\"<script>alert('xss')</script>\");",
									"});",
									"",
									"pm.test('X-Content-Type-Options header present', function () {",
									"    pm.expect(",
									"        pm.response.headers.has('X-Content-Type-Options') ||",
									"        pm.response.headers.has('x-content-type-options')",
									"    ).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			],
			"description": "Security header verification and attack vector testing including CORS, CSP, HSTS, SQL injection, and XSS"
		},
