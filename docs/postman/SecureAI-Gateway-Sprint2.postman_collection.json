				{
					"name": "PostgreSQL Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/actuator/health",
							"host": ["{{base_url}}"],
							"path": ["actuator", "health"]
						},
						"description": "Check PostgreSQL health via Spring Boot Actuator (db component)"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Health endpoint returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Database is UP', function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.components && jsonData.components.db) {",
									"        pm.expect(jsonData.components.db.status).to.eql('UP');",
									"    } else {",
									"        pm.expect(jsonData.status).to.eql('UP');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
