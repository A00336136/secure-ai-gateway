# ═══════════════════════════════════════════════════════════════
# Secure AI Gateway — Environment Variables Template
# Copy this to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to Git! It is listed in .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Database ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=secureai
DB_USERNAME=secureai_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── PostgreSQL Container ──
POSTGRES_DB=secureai
POSTGRES_USER=secureai_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──
JWT_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARS_FOR_HS256_SIGNING

# ── Ollama ──
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
LLAMAGUARD_MODEL=llamaguard3:8b

# ── Guardrails ──
NEMO_GUARDRAILS_URL=http://nemo-guardrails:8001
PRESIDIO_URL=http://presidio:5002

# ── SonarQube ──
SONAR_JDBC_URL=jdbc:postgresql://postgres:5432/sonarqube
SONAR_JDBC_USERNAME=secureai_user
SONAR_JDBC_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Grafana ──
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
